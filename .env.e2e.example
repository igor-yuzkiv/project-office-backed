APP_NAME="Task Manager"
APP_ENV=e2e
# Generate with: php artisan key:generate --env=e2e --show
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8100

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Faster hashing keeps the e2e seed/login fast
BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Dedicated e2e database — isolated from PHPUnit's task_manager_test.
# Created by docker-entrypoint-initdb.d/01-init.sh and
# scripts/init_testing_pg_databases.sh.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=task_manager_e2e
DB_USERNAME=task_manager
DB_PASSWORD=task_manager

# The SPA is served same-origin by `php artisan serve --env=e2e` on :8100,
# so localhost:8100 must be a stateful Sanctum domain and cookies must be
# non-secure/lax for plain HTTP.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_COOKIE=e2e_task_manager_session
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8100,127.0.0.1,127.0.0.1:8100

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

SCOUT_DRIVER=database

CACHE_DRIVER=array
CACHE_STORE=array

MAIL_MAILER=array
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Attachments use the s3 provider (only supported provider); e2e does not
# exercise uploads yet, so these values are not reached.
ATTACHMENTS_STORAGE=s3
ATTACHMENTS_AWS_ACCESS_KEY_ID=minioadmin
ATTACHMENTS_AWS_SECRET_ACCESS_KEY=minioadmin
ATTACHMENTS_AWS_DEFAULT_REGION=us-east-1
ATTACHMENTS_AWS_BUCKET=task-manager-attachments
ATTACHMENTS_AWS_ENDPOINT=http://localhost:9000
ATTACHMENTS_AWS_USE_PATH_STYLE_ENDPOINT=true
ATTACHMENTS_TEMPORARY_URL_TTL_MINUTES=15

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

# Frontend build (npm run build -- --mode e2e) reads these VITE_ vars.
# API is same-origin/relative; realtime is disabled for e2e.
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL="/api"
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_WS_PORT=
VITE_REVERB_WSS_PORT=
VITE_REVERB_SCHEME=
VITE_CLIENT_BROADCAST_CHANNEL="client-channel"

# --- Playwright (Node) settings, loaded by playwright.config.ts via dotenv ---
E2E_BASE_URL=http://localhost:8100
E2E_PORT=8100
E2E_USER_EMAIL=e2e@example.com
E2E_USER_PASSWORD=password

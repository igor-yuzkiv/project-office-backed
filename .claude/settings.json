{
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "Bash(git status)",
            "Bash(git status *)",
            "Bash(git diff)",
            "Bash(git diff *)",
            "Bash(git log)",
            "Bash(git log *)",
            "Bash(git branch)",
            "Bash(git branch *)",
            "Bash(ls *)",
            "Bash(find *)",
            "Bash(grep *)",
            "Bash(composer dump-autoload)",
            "Bash(composer dump-autoload *)",
            "Bash(php artisan *)",
            "Bash(php -l *)",
            "Bash(./vendor/bin/pint)",
            "Bash(./vendor/bin/pint *)",
            "Bash(./vendor/bin/phpstan analyse)",
            "Bash(./vendor/bin/phpstan analyse *)",
            "Bash(npm run format:check)",
            "Bash(npm run format:check *)",
            "Bash(npm run lint:check)",
            "Bash(npm run lint:check *)",
            "Bash(npm run types:check)",
            "Bash(npm run types:check *)",
            "Bash(npm run build)",
            "Bash(npm run build *)",
            "Read(//tmp/**)"
        ],
        "ask": [
            "Bash(git commit)",
            "Bash(git commit *)",
            "Bash(git push)",
            "Bash(git push *)",
            "Bash(composer install)",
            "Bash(composer install *)",
            "Bash(composer require *)",
            "Bash(composer remove *)",
            "Bash(composer update)",
            "Bash(composer update *)",
            "Bash(npm install)",
            "Bash(npm install *)",
            "Bash(npm uninstall *)",
            "Bash(npm update)",
            "Bash(npm update *)",
            "Bash(./scripts/init_testing_pg_databases.sh)",
            "Bash(./scripts/init_testing_pg_databases.sh *)"
        ],
        "deny": [
            "Bash(git reset)",
            "Bash(git reset *)",
            "Bash(git rebase)",
            "Bash(git rebase *)",
            "Bash(git merge)",
            "Bash(git merge *)",
            "Bash(git clean)",
            "Bash(git clean *)",
            "Bash(git checkout)",
            "Bash(git checkout *)",
            "Bash(git restore)",
            "Bash(git restore *)",
            "Bash(git stash)",
            "Bash(git stash *)",
            "Bash(git branch -D *)",
            "Bash(php artisan migrate)",
            "Bash(php artisan migrate *)",
            "Bash(php artisan migrate:*)",
            "Read(./.env)",
            "Read(./.env.backup)",
            "Read(./.env.e2e)",
            "Read(./.env.production)",
            "Read(./.env.testing)",
            "Read(./auth.json)",
            "Read(./scripts/.env)",
            "Read(./storage/*.key)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-test-infra-edits.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pint-edited-app-file.sh"
                    }
                ]
            }
        ]
    }
}

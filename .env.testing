APP_NAME="Task Manager"
APP_ENV=testing
APP_KEY=base64:tCGfYg384u4KVNKaA/zKyMFI2WjCUHXFeywt5GPXizU=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Faster hashing during tests
BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Dedicated testing database (see docker-entrypoint-initdb.d/01-init.sh
# and scripts/init_testing_pg_database.sh)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=task_manager_test
DB_USERNAME=task_manager
DB_PASSWORD=task_manager

# In-memory / synchronous drivers keep the suite isolated and fast
SESSION_DRIVER=array
SESSION_LIFETIME=120

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

SCOUT_DRIVER=database

CACHE_DRIVER=array
CACHE_STORE=array

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=array
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost

# Attachments use the s3 provider (only supported provider); tests fake the disk,
# so these values are not used to reach a live endpoint.
ATTACHMENTS_STORAGE=s3
ATTACHMENTS_AWS_ACCESS_KEY_ID=minioadmin
ATTACHMENTS_AWS_SECRET_ACCESS_KEY=minioadmin
ATTACHMENTS_AWS_DEFAULT_REGION=us-east-1
ATTACHMENTS_AWS_BUCKET=task-manager-attachments
ATTACHMENTS_AWS_ENDPOINT=http://localhost:9000
ATTACHMENTS_AWS_USE_PATH_STYLE_ENDPOINT=true
ATTACHMENTS_TEMPORARY_URL_TTL_MINUTES=15

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

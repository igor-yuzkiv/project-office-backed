APP_NAME="Project Office"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local Docker services
ROOT_PASSWORD=root
POSTGRES_DB_NAME=task_manager
DB_USER=task_manager
DB_USER_PASSWORD=task_manager

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=task_manager
DB_USERNAME=task_manager
DB_PASSWORD=task_manager
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_COOKIE=project_office_session

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
SANCTUM_TOKEN_PREFIX=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Attachments use the dedicated "attachments" filesystem disk.
# These defaults target the MinIO service from docker-compose.yml.
ATTACHMENTS_STORAGE=s3
ATTACHMENTS_AWS_ACCESS_KEY_ID=minioadmin
ATTACHMENTS_AWS_SECRET_ACCESS_KEY=minioadmin
ATTACHMENTS_AWS_DEFAULT_REGION=us-east-1
ATTACHMENTS_AWS_BUCKET=task-manager-attachments
ATTACHMENTS_AWS_ENDPOINT=http://127.0.0.1:9000
ATTACHMENTS_AWS_USE_PATH_STYLE_ENDPOINT=true
ATTACHMENTS_TEMPORARY_URL_TTL_MINUTES=15

SCOUT_DRIVER=collection
SCOUT_PREFIX=
SCOUT_QUEUE=false

HORIZON_NAME=
HORIZON_DOMAIN=
HORIZON_PATH=horizon

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=/api
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_WS_PORT="${REVERB_PORT}"
VITE_REVERB_WSS_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
